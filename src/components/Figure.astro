---
/** Props (fully backward compatible — no changes to public interface):
 *  - src: string
 *  - alt?: string
 *  - width?: string = "100%"
 *  - maxWidth?: string = "none"
 *  - caption?: string
 *  - lightbox?: boolean = true
 */
interface Props {
  src: string;
  alt?: string;
  width?: string;
  maxWidth?: string;
  caption?: string;
  lightbox?: boolean;
}

const {
  src,
  alt = "",
  width = "100%",
  maxWidth = "none",
  caption,
  lightbox = true,
} = Astro.props as Props;

const styleObj = { width, maxWidth, marginInline: "auto" };
---

<!--
  .project-prose scopes the CSS counter so pages without figures are unaffected.
  The counter is incremented by each <figure class="zine-figure"> inside that context.
  The ::before on figcaption renders "FIG. 01 — " automatically.
-->
<figure class="not-prose my-5 zine-figure" style={styleObj}>
  {lightbox ? (
    <>
      {/* Opens the shared #site-lightbox in Layout.astro */}
      <button
        type="button"
        class="group block w-full overflow-hidden rounded-xl border border-border p-0 m-0 bg-transparent
               transition-all hover:border-accent/50
               hover:shadow-[0_4px_20px_color-mix(in_srgb,var(--color-accent)_10%,transparent)]
               focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent"
        data-lb-src={src}
        data-lb-alt={alt}
        data-lb-caption={caption ?? ""}
        aria-label={alt ? `Open image: ${alt}` : "Open image"}
      >
        <img
          src={src}
          alt={alt}
          loading="lazy"
          decoding="async"
          class="w-full rounded-xl object-cover transition-transform duration-300 group-hover:scale-[1.01]"
        />
      </button>

      {caption && (
        <figcaption class="zine-caption mt-2 text-left">
          {caption}
        </figcaption>
      )}
    </>
  ) : (
    <>
      <img
        src={src}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="w-full rounded-xl border border-border object-cover"
      />
      {caption && (
        <figcaption class="zine-caption mt-2 text-left">
          {caption}
        </figcaption>
      )}
    </>
  )}
</figure>

<!--
  CSS counter for FIG numbering.
  .project-prose is the scope; counter increments on each .zine-figure.
  ::before on .zine-caption generates "FIG. 01 — " in mono.
  Scoped via a <style> block here so it doesn't bleed globally.
  prefers-reduced-motion: the counter is CSS-only, no motion concerns.
-->
<style>
  /* Initialise the counter on the prose scope.
     Using :where() avoids specificity wars. */
  :where(.project-prose) {
    counter-reset: fig-counter;
  }

  /* Each figure that lives inside .project-prose increments the counter */
  :where(.project-prose) .zine-figure {
    counter-increment: fig-counter;
  }

  /* Caption gets the FIG. prefix prepended automatically */
  :where(.project-prose) .zine-caption::before {
    content: "FIG. " counter(fig-counter, decimal-leading-zero) " · ";
    font-family: ui-monospace, SFMono-Regular, Menlo, "Cascadia Code", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 55%, transparent);
    margin-right: 0.25em;
  }

  /* Caption base style */
  .zine-caption {
    font-size: 0.8rem;
    line-height: 1.5;
    color: color-mix(in srgb, currentColor 65%, transparent);
    font-style: italic;
  }

  /* Outside .project-prose: no counter prefix, caption still styled */
  .zine-figure .zine-caption::before {
    content: none;
  }

  :where(.project-prose) .zine-figure .zine-caption::before {
    content: "FIG. " counter(fig-counter, decimal-leading-zero) " · ";
  }
</style>
