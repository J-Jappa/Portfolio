---
import Hr from "./Hr.astro";
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import { SITE } from "@/config";
import IconLinkedIn from "@/assets/icons/IconLinkedin.svg";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

// Mark "/" as active on both "/" and "/projects/*"
const isActive = (href: string) => {
  if (href === "/")
    return currentPath === "/" || currentPath.startsWith("/projects");
  return currentPath === href || currentPath.startsWith(href);
};
---

<header class="mb-0">
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
  >
    Skip to content
  </a>

  <div
    id="nav-container"
    class="mx-auto flex max-w-app flex-col items-center justify-between sm:flex-row"
  >
    <div
      id="top-nav-wrap"
      class="relative flex w-full items-baseline justify-between bg-background p-4 sm:items-center sm:py-5"
    >
      <!-- Brand -->
      <a
        href="/"
        title="always be optimising"
        class="group flex flex-col gap-0.5 py-1 whitespace-nowrap no-underline sm:my-auto"
        aria-label="Jasper Japp, home"
      >
        <span
          class="text-xl leading-tight font-semibold tracking-tight sm:text-2xl"
          style="font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;"
        >
          Jasper Japp
        </span>
        <span
          class="t-label opacity-50 transition-opacity group-hover:opacity-80"
        >
          always be optimising
        </span>
      </a>

      <nav
        id="nav-menu"
        class="flex w-full flex-col items-center sm:ms-4 sm:flex-row sm:justify-end sm:space-x-1 sm:py-0"
      >
        <!-- Hamburger (mobile only) -->
        <button
          id="menu-btn"
          class="focus-outline self-end p-2 sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>

        <!-- Nav items -->
        <ul
          id="menu-items"
          class:list={[
            /* Mobile: full-width column, polished card-like panel */
            "mt-2 flex w-full flex-col gap-1 rounded-xl border border-border bg-muted/60 px-3 py-3 shadow-sm backdrop-blur-sm",
            /* Desktop: inline row, no panel */
            "hidden sm:mt-0 sm:flex sm:w-auto sm:flex-row sm:items-center sm:gap-x-1 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none",
          ]}
        >
          <li>
            <a
              href="/"
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-accent sm:rounded-md sm:px-2 sm:py-1",
                { "active-nav text-accent": isActive("/") },
                { "text-foreground": !isActive("/") },
              ]}
            >
              Projects
            </a>
          </li>
          <li>
            <a
              href="/about"
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-accent sm:rounded-md sm:px-2 sm:py-1",
                { "active-nav text-accent": isActive("/about") },
                { "text-foreground": !isActive("/about") },
              ]}
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/experience"
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-accent sm:rounded-md sm:px-2 sm:py-1",
                { "active-nav text-accent": isActive("/experience") },
                { "text-foreground": !isActive("/experience") },
              ]}
            >
              Experience
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-accent sm:rounded-md sm:px-2 sm:py-1",
                { "active-nav text-accent": isActive("/contact") },
                { "text-foreground": !isActive("/contact") },
              ]}
            >
              Contact
            </a>
          </li>

          <!-- PHOTO//SCOPE: terminal-styled, matching the page it opens -->
          <li class="px-3 py-2 sm:ms-2 sm:p-0">
            <a
              href="/photoscope/"
              data-astro-reload
              class="scope-link"
              aria-label="PHOTO//SCOPE, film photography"
              title="PHOTO//SCOPE"
            >
              <img
                src="/logo.svg"
                alt=""
                class="scope-link-mark"
                width="10"
                height="18"
              />
              <span>PHOTO//SCOPE</span>
            </a>
          </li>

          <!-- Divider (mobile only) -->
          <li
            class="my-1 border-t border-border/50 sm:hidden"
            aria-hidden="true"
          >
          </li>

          <!-- LinkedIn icon -->
          <li class="sm:ms-2">
            <a
              href={SITE.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center rounded-lg p-2.5 transition-colors hover:text-accent sm:rounded-md sm:p-1.5"
              aria-label="LinkedIn"
              title="LinkedIn"
            >
              <IconLinkedIn class="h-4.5 w-4.5" />
              <span class="sr-only">LinkedIn</span>
            </a>
          </li>

          <!-- Theme toggle -->
          {
            SITE.lightAndDarkMode && (
              <li>
                <button
                  id="theme-btn"
                  class="focus-outline relative flex items-center justify-center rounded-lg p-2.5 transition-colors sm:rounded-md sm:p-1.5 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="h-4.5 w-4.5 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute h-4.5 w-4.5 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>

  <Hr class="m-0" />
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");
    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");
      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }
  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>

<style>
  /* Terminal-styled pill in PHOTO//SCOPE's own aesthetic. The pill stays
     fully opaque (element opacity would wash the dark background out on
     the light theme); the resting state is dimmed via colour instead. */
  .scope-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 4px 10px;
    border: 1px solid rgba(57, 255, 136, 0.3);
    border-radius: 4px;
    background: #050b08;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, "Cascadia Code", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(77, 255, 155, 0.75);
    text-decoration: none;
    text-shadow: 0 0 6px rgba(57, 255, 136, 0.25);
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      letter-spacing 0.25s ease;
  }
  .scope-link:hover,
  .scope-link:focus-visible {
    color: #4dff9b;
    text-shadow: 0 0 6px rgba(57, 255, 136, 0.4);
    border-color: rgba(57, 255, 136, 0.7);
    box-shadow:
      0 0 16px rgba(57, 255, 136, 0.28),
      inset 0 0 12px rgba(57, 255, 136, 0.06);
    letter-spacing: 0.26em;
    outline: none;
  }
  .scope-link-mark {
    display: block;
    height: 15px;
    width: auto;
    filter: drop-shadow(0 0 4px rgba(57, 255, 136, 0.35));
  }
</style>
