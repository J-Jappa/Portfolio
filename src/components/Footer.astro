---
import { SITE } from "@/config";
const year = new Date().getFullYear();
---

<footer class="mt-12 border-t border-border">
  <div class="mx-auto max-w-app px-4 py-8">
    <!-- Top row: identity + nav -->
    <div
      class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between"
    >
      <!-- Identity -->
      <div class="flex flex-col gap-1">
        <span
          class="text-base font-semibold tracking-tight"
          style="font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;"
        >
          Jasper Japp
        </span>
        <span class="t-label opacity-50">Sydney, Australia</span>
      </div>

      <!-- Footer nav -->
      <nav
        class="flex flex-wrap gap-x-5 gap-y-2"
        aria-label="Footer navigation"
      >
        <a
          href="/"
          class="t-label no-underline opacity-60 transition-opacity hover:text-accent hover:opacity-100"
        >
          Projects
        </a>
        <a
          href="/about"
          class="t-label no-underline opacity-60 transition-opacity hover:text-accent hover:opacity-100"
        >
          About
        </a>
        <a
          href="/experience"
          class="t-label no-underline opacity-60 transition-opacity hover:text-accent hover:opacity-100"
        >
          Experience
        </a>
        <a
          href="/contact"
          class="t-label no-underline opacity-60 transition-opacity hover:text-accent hover:opacity-100"
        >
          Contact
        </a>
        {
          SITE.linkedinUrl && (
            <a
              href={SITE.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="t-label no-underline opacity-60 transition-opacity hover:text-accent hover:opacity-100"
            >
              LinkedIn ↗
            </a>
          )
        }
      </nav>
    </div>

    <!-- Bottom row: copyright -->
    <div class="mt-6 border-t border-border/50 pt-5">
      <p class="t-label opacity-40">© {year} Jasper Japp</p>
    </div>
  </div>
</footer>
