---
import Layout from "../../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { createHash } from "crypto";

function thumbSrc(src: string): string {
  const hash = createHash("md5").update(src).digest("hex").slice(0, 12);
  return `/thumbs/${hash}.webp`;
}

/** Extract the year from an ISO date string, or return null */
function yearOf(date?: string): string | null {
  if (!date) return null;
  const m = date.match(/^(\d{4})/);
  return m ? m[1] : null;
}

export async function getStaticPaths() {
  const projects = (await getCollection(
    "projects",
    ({ data }) => !data.draft
  )) as CollectionEntry<"projects">[];
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await project.render();
const p = project.data;

const year = yearOf(p.date);
---

<Layout title={p.title} description={p.summary} ogImage={p.hero ?? undefined}>
  <article class="max-w-none">
    {/* ── Back link ──────────────────────────────────────────────── */}
    <a
      href="/"
      class="group inline-flex items-center gap-1.5 rounded-lg border border-border px-3 py-1.5 text-sm glow-accent transition-all hover:border-accent/60 hover:text-accent"
    >
      <span
        aria-hidden="true"
        class="transition-transform group-hover:-translate-x-0.5">←</span
      >
      <span class="u-ink">All projects</span>
    </a>

    {/* ── Title + summary ──────────────────────────────────────── */}
    <header class="mt-5 mb-6">
      <h1
        class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
        style="font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;"
      >
        {p.title}
      </h1>
      <p class="mt-2 max-w-[65ch] text-base leading-relaxed opacity-80">
        {p.summary}
      </p>
    </header>

    {/* ── Spec-sheet strip ─────────────────────────────────────── */}
    {
      /*
        Engineering drawing title block — light hairline border,
        mono labels, compact grid. Only renders non-empty fields.
    */
    }
    <div
      class="relative mb-8 rounded-xl border border-border bg-muted/40 before:absolute before:top-2.5 before:left-2.5 before:h-2 before:w-2 before:border-t before:border-l before:border-accent/30 after:absolute after:right-2.5 after:bottom-2.5 after:h-2 after:w-2 after:border-r after:border-b after:border-accent/30 dark:bg-muted/30"
    >
      <dl
        class="grid grid-cols-2 divide-y divide-border sm:grid-cols-3 sm:divide-x sm:divide-y-0 lg:grid-cols-4"
      >
        {
          p.role && (
            <div class="px-4 py-3">
              <dt class="mb-1 t-label">Role</dt>
              <dd class="text-sm font-medium text-foreground">{p.role}</dd>
            </div>
          )
        }
        {
          year && (
            <div class="px-4 py-3">
              <dt class="mb-1 t-label">Date</dt>
              <dd class="text-sm font-medium text-foreground">{year}</dd>
            </div>
          )
        }
        {
          p.tags?.length > 0 && (
            <div class="col-span-2 px-4 py-3 sm:col-span-1 lg:col-span-2">
              <dt class="mb-1.5 t-label">Tags</dt>
              <dd class="flex flex-wrap gap-1.5">
                {p.tags.map((tag: string) => (
                  <span class="rounded border border-border bg-background px-2 py-0.5 t-label text-foreground/70">
                    {tag}
                  </span>
                ))}
              </dd>
            </div>
          )
        }
        {
          (p.repo || p.link) && (
            <div class="col-span-2 border-t border-border px-4 py-3 sm:col-span-1 sm:border-t-0">
              <dt class="mb-1 t-label">Links</dt>
              <dd class="flex gap-3 text-sm">
                {p.repo && (
                  <a
                    href={p.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent underline-offset-4 hover:underline"
                  >
                    Repo ↗
                  </a>
                )}
                {p.link && (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent underline-offset-4 hover:underline"
                  >
                    Live ↗
                  </a>
                )}
              </dd>
            </div>
          )
        }
      </dl>
    </div>

    {/* ── Image strip (thumbnail lightbox) ─────────────────────── */}
    {
      /*
        Keeps the EXACT thumbSrc md5 → /thumbs/*.webp mechanism.
        data-open="dlg-{i}" preserved as-is; Layout.astro's global
        delegated handler listens for this attribute.
    */
    }
    {
      p.images?.length > 0 && (
        <div class="mb-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {p.images.map((img: { src: string; alt?: string }, i: number) => (
            <>
              <div class="group relative overflow-hidden rounded-xl border border-border transition-all hover:border-accent/50 hover:shadow-[0_4px_20px_color-mix(in_srgb,var(--color-accent)_10%,transparent)]">
                <button
                  class="m-0 block aspect-video w-full overflow-hidden border-0 bg-transparent p-0"
                  data-open={`dlg-${i}`}
                  aria-label={`Open image ${i + 1}: ${img.alt ?? p.title}`}
                >
                  <img
                    src={thumbSrc(img.src)}
                    alt={img.alt ?? p.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                    loading="lazy"
                    decoding="async"
                  />
                </button>
              </div>

              <dialog
                id={`dlg-${i}`}
                data-lightbox
                class="border-0 bg-transparent p-0"
              >
                <div class="m-4 sm:m-8">
                  <div class="relative overflow-hidden rounded-xl bg-white shadow-2xl dark:bg-neutral-900">
                    <img
                      src={img.src}
                      alt={img.alt ?? p.title}
                      class="block h-auto max-h-[calc(100vh-3rem)] w-auto max-w-[calc(100vw-3rem)] sm:max-h-[calc(100vh-6rem)] sm:max-w-[calc(100vw-6rem)]"
                      decoding="async"
                    />
                    <form method="dialog">
                      <button
                        class="absolute top-2 right-2 rounded-md border border-border bg-white/85 px-3 py-1 text-sm hover:border-accent/60 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-dashed dark:bg-neutral-800/85"
                        aria-label="Close lightbox"
                      >
                        Close
                      </button>
                    </form>
                  </div>
                </div>
              </dialog>
            </>
          ))}
        </div>
      )
    }

    {/* ── Outcomes highlight block ──────────────────────────────── */}
    {
      p.outcomes?.length > 0 && (
        <section
          class="mb-8 rounded-xl border border-border bg-muted/30 px-5 py-4 dark:bg-muted/20"
          aria-label="Outcomes"
          data-animate
        >
          <h2 class="mb-4 flex items-baseline gap-2 t-label">
            Outcomes
            <span class="text-accent/60" aria-hidden="true">
              //
            </span>
          </h2>
          <ul class="m-0 list-none space-y-2.5 p-0">
            {p.outcomes.map((o: string) => (
              <li class="flex items-baseline gap-2.5">
                <span
                  class="shrink-0 t-label text-accent select-none"
                  aria-hidden="true"
                >
                  ↳
                </span>
                <span class="text-sm leading-snug text-foreground">{o}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* ── Prose body ───────────────────────────────────────────── */}
    {
      /*
        Running text is centred in a fixed 42rem (max-w-2xl) column.
        The measure must be an absolute unit shared by every element:
        ch scales with each element's own font size, so headings sized
        in ch get a wider box than paragraphs and their left edges
        stop lining up. Figures / ImageRows inside MDX break out to
        full column width via .not-prose (already on Figure/ImageRow).
    */
    }
    <section class="project-prose mt-2">
      <div
        class="prose max-w-none dark:prose-invert prose-headings:mx-auto prose-headings:max-w-2xl prose-headings:font-semibold prose-headings:tracking-tight prose-p:mx-auto prose-p:max-w-2xl prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-blockquote:mx-auto prose-blockquote:max-w-2xl prose-ol:mx-auto prose-ol:max-w-2xl prose-ul:mx-auto prose-ul:max-w-2xl prose-hr:mx-auto prose-hr:max-w-2xl prose-li:text-foreground"
      >
        <Content />
      </div>
    </section>
  </article>

  {/* Scroll-reveal observer */}
  <script>
    const obs = new IntersectionObserver(
      entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll("[data-animate]").forEach(el => obs.observe(el));
    document.addEventListener("astro:after-swap", () => {
      document
        .querySelectorAll("[data-animate]")
        .forEach(el => obs.observe(el));
    });
  </script>
</Layout>
