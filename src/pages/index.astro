---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { createHash } from "crypto";

// Maps an original image src to its pre-generated thumbnail path.
// Matches the hash logic in scripts/gen-thumbs.mjs.
function thumbSrc(src: string): string {
  const hash = createHash("md5").update(src).digest("hex").slice(0, 12);
  return `/thumbs/${hash}.webp`;
}

const projects = (await getCollection(
  "projects"
)) as CollectionEntry<"projects">[];

// Featured first, then by `order` (asc), then by date (newest first)
const sorted = [...projects].sort((a, b) => {
  const fa = a.data.featured ? 1 : 0;
  const fb = b.data.featured ? 1 : 0;
  if (fb - fa) return fb - fa;

  const oa = a.data.order ?? 0;
  const ob = b.data.order ?? 0;
  if (oa !== ob) return oa - ob;

  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
});
---

<Layout title="Projects" description="Engineering portfolio: projects and write-ups">

  <!-- Hero -->
  <div class="mb-8">
    <p class="opacity-80 max-w-xl">
      Engineer focused on tricky problems whether in aerodynamics, composite structures, or applied ML.
      
    </p>
  </div>

  <div class="flex flex-col gap-8" id="project-list">
    {
      sorted.map((p) => (
        <article class="transition" data-animate>
          <a
            href={`/projects/${p.slug}/`}
            class="group card-hover block rounded-2xl border p-5 no-underline
                   outline-offset-2 transition
                   bg-white/70 hover:bg-accent/[0.06]
                   dark:bg-neutral-900/50 dark:hover:bg-accent/[0.12]
                   hover:border-accent/60 hover:shadow-lg hover:-translate-y-0.5
                   focus-visible:outline-dashed focus-visible:outline-2 focus-visible:outline-accent"
            data-analytics="project"
            data-project={p.slug}
            data-title={p.data.title}
          >
            <h2 class="text-lg font-semibold tracking-tight">
  <span class="u-ink">{p.data.title}</span>
</h2>

            <p class="mt-1 text-sm opacity-80">{p.data.summary}</p>

            <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
              {(p.data.images ?? [])
                .slice(0, 3)
                .map((img: { src: string; alt?: string }) => (
                  <div class="aspect-[21/9] overflow-hidden rounded-lg">
                    <img
                      src={thumbSrc(img.src)}
                      alt={img.alt ?? p.data.title}
                      class="h-full w-full object-cover transition
                             group-hover:brightness-105 group-hover:saturate-110"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
            </div>

            {(() => {
              const stat = (p.data.outcomes ?? []).find((o: string) => /\d/.test(o));
              return stat ? (
                <p class="mt-3 text-xs text-accent font-medium">↳ {stat}</p>
              ) : null;
            })()}

            {p.data.tags?.length ? (
              <div class="mt-2 text-xs opacity-70">{p.data.tags.join(" · ")}</div>
            ) : null}

            <div class="mt-2 flex items-center gap-1 text-sm opacity-70">
              <span class="transition group-hover:text-accent">View project</span>
              <span class="translate-x-0 transition group-hover:translate-x-1">→</span>
            </div>
          </a>
        </article>
      ))
    }
  </div>
</Layout>

<script>
  function initAnimations() {
    const els = document.querySelectorAll<HTMLElement>("[data-animate]");
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    els.forEach((el, i) => {
      el.style.transitionDelay = `${i * 55}ms`;
      observer.observe(el);
    });
  }
  initAnimations();
  document.addEventListener("astro:after-swap", initAnimations);
</script>
